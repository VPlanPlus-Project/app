# frozen_string_literal: true

# Required secrets (GitHub Actions):
#   IOS_CERTIFICATE_P12       – base64-encoded Apple Distribution .p12
#   IOS_CERTIFICATE_PASSWORD  – password for the .p12
#   IOS_PROVISIONING_PROFILE  – base64-encoded App Store provisioning profile (.mobileprovision)
#   APP_STORE_KEY_ID          – App Store Connect API key ID
#   APP_STORE_ISSUER_ID       – App Store Connect API issuer ID
#   APP_STORE_KEY_CONTENT     – base64-encoded contents of the .p8 API key file
#                               Encode with: base64 -i AuthKey_XXXXXX.p8 | pbcopy

default_platform(:ios)

CI_KEYCHAIN_NAME = "ci_keychain"

CHANGELOG_PATH = File.expand_path("../.deploy/CHANGELOG", __dir__)
DEFAULT_CHANGELOG = "Es wurden keine Änderungen angegeben."

platform :ios do
  def read_changelog
    if File.exist?(CHANGELOG_PATH)
      UI.message("Changelog found at #{CHANGELOG_PATH}")
      File.read(CHANGELOG_PATH)
    else
      UI.important("Changelog not found at #{CHANGELOG_PATH}, using default message")
      DEFAULT_CHANGELOG
    end
  end

  def authenticate_api
    app_store_connect_api_key(
      key_id:        ENV["APP_STORE_KEY_ID"],
      issuer_id:     ENV["APP_STORE_ISSUER_ID"],
      key_content:   ENV["APP_STORE_KEY_CONTENT"],
      is_key_content_base64: true
    )
  end

  desc "Sync build number with TestFlight"
  lane :sync_build_number do
    authenticate_api
    
    # Get marketing version from Xcode project (set by Version.xcconfig)
    marketing_version = get_version_number(xcodeproj: "iosApp.xcodeproj")
    
    # Sync build number with latest TestFlight build for this marketing version
    new_build = latest_testflight_build_number(
      initial_build_number: 0,
      version: marketing_version
    ) + 1
    
    increment_build_number(
      build_number: new_build,
      xcodeproj: "iosApp.xcodeproj"
    )
    
    UI.success("Version set to #{marketing_version} (#{new_build})")
  end

  desc "Build the app and produce a signed .ipa"
  lane :build_ipa do
    sync_build_number
    
    # ── Install certificate & provisioning profile ─────────────────────────
    cert_path    = File.expand_path("../ci_certificate.p12", __dir__)
    profile_path = File.expand_path("../ci_profile.mobileprovision", __dir__)

    keychain_name     = CI_KEYCHAIN_NAME
    keychain_password = SecureRandom.hex

    # Delete any leftover keychain from a previous run before creating a fresh one.
    delete_keychain(name: keychain_name) if File.exist?(File.expand_path("~/Library/Keychains/#{keychain_name}-db"))

    create_keychain(
      name:            keychain_name,
      password:        keychain_password,
      default_keychain: true,
      unlock:          true,
      timeout:         3600,
      lock_when_sleeps: false
    )

    import_certificate(
      certificate_path:     cert_path,
      certificate_password: ENV["IOS_CERTIFICATE_PASSWORD"],
      keychain_name:        keychain_name,
      keychain_password:    keychain_password
    )

    install_provisioning_profile(path: profile_path)

    # ── Resolve the provisioning profile UUID so we can pass it to xcodebuild
    profile_uuid = sh(
      "security cms -D -i #{profile_path.shellescape} | " \
      "plutil -extract UUID xml1 -o - - | " \
      "sed -n 's/.*<string>\\(.*\\)<\\/string>.*/\\1/p'",
      log: false
    ).strip

    UI.user_error!("Could not read provisioning profile UUID from #{profile_path}") if profile_uuid.empty?

    # ── Build ──────────────────────────────────────────────────────────────
    build_app(
      scheme:                      "iosApp",
      project:                     "iosApp.xcodeproj",
      configuration:               "Release",
      export_method:               "app-store",
      clean:                       true,
      output_directory:            ENV["IPA_OUTPUT_DIR"] || File.expand_path("../build", __dir__),
      output_name:                 "VPlanPlus.ipa",
      xcargs:                      "CODE_SIGN_STYLE=Manual " \
                                   "DEVELOPMENT_TEAM=BYCH2H5X5G " \
                                   "CODE_SIGN_IDENTITY=\"Apple Distribution\" " \
                                   "PROVISIONING_PROFILE_SPECIFIER=#{profile_uuid}",
      export_options: {
        method:                    "app-store",
        teamID:                    "BYCH2H5X5G",
        signingStyle:              "manual",
        provisioningProfiles: {
          "plus.vplan.app.VPlanPlus" => profile_uuid
        }
      }
    )

    # ── Cleanup ────────────────────────────────────────────────────────────
    delete_keychain(name: keychain_name)
  end

  # --- Channel Lanes ---

  desc "Release for internal testers"
  lane :internal do
    authenticate_api
    upload_to_testflight(
      ipa: "./build/VPlanPlus.ipa",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Closed testing"
  lane :closed do
    authenticate_api
    upload_to_testflight(
      ipa: "./build/VPlanPlus.ipa",
      groups: ["Closed"],
      changelog: read_changelog,
      distribute_external: true,
      skip_waiting_for_build_processing: false
    )
  end

  desc "Open testing"
  lane :open do
    authenticate_api
    upload_to_testflight(
      ipa: "./build/VPlanPlus.ipa",
      groups: ["Open"],
      changelog: read_changelog,
      distribute_external: true,
      skip_waiting_for_build_processing: false
    )
  end

  desc "Production"
  lane :production do
    authenticate_api
    upload_to_testflight(
      ipa: "./build/VPlanPlus.ipa",
      skip_submission: true,
      distribute_external: false,
      skip_waiting_for_build_processing: false
    )
  end

  error do |lane, exception|
    delete_keychain(name: CI_KEYCHAIN_NAME) if File.exist?(File.expand_path("~/Library/Keychains/#{CI_KEYCHAIN_NAME}-db"))
  end
end
