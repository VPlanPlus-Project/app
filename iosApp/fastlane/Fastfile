# frozen_string_literal: true

# Required secrets (GitHub Actions):
#   IOS_CERTIFICATE_P12       – base64-encoded Apple Distribution .p12
#   IOS_CERTIFICATE_PASSWORD  – password for the .p12
#   IOS_PROVISIONING_PROFILE  – base64-encoded App Store provisioning profile (.mobileprovision)
#   APP_STORE_KEY_ID          – App Store Connect API key ID
#   APP_STORE_ISSUER_ID       – App Store Connect API issuer ID
#   APP_STORE_KEY_CONTENT     – Contents of the .p8 API key file

default_platform(:ios)

platform :ios do
  desc "Build and upload a new beta build to TestFlight"
  lane :beta do |options|
    # ── API key for App Store Connect ──────────────────────────────────────
    app_store_connect_api_key(
      key_id:        ENV["APP_STORE_KEY_ID"],
      issuer_id:     ENV["APP_STORE_ISSUER_ID"],
      key_content:   ENV["APP_STORE_KEY_CONTENT"],
      is_key_content_base64: false
    )

    # ── Install certificate & provisioning profile ─────────────────────────
    keychain_name     = "ci_keychain"
    keychain_password = SecureRandom.hex

    create_keychain(
      name:            keychain_name,
      password:        keychain_password,
      default_keychain: true,
      unlock:          true,
      timeout:         3600,
      lock_when_sleeps: false
    )

    import_certificate(
      certificate_path:     "ci_certificate.p12",
      certificate_password: ENV["IOS_CERTIFICATE_PASSWORD"],
      keychain_name:        keychain_name,
      keychain_password:    keychain_password
    )

    install_provisioning_profile(path: "ci_profile.mobileprovision")

    # ── Resolve the provisioning profile UUID so we can pass it to xcodebuild
    profile_uuid = sh(
      "security cms -D -i ci_profile.mobileprovision | " \
      "plutil -extract UUID xml1 -o - - | " \
      "sed -n 's/.*<string>\\(.*\\)<\\/string>.*/\\1/p'",
      log: false
    ).strip

    # ── Update version / build number from tag ─────────────────────────────
    tag = options[:tag] || ENV["TAG_NAME"] || ""
    # Strip leading "v" and any pre-release suffix (e.g. v1.2.3-internal → 1.2.3)
    marketing_version = tag.sub(/^v/, "").split("-").first

    increment_version_number(
      version_number: marketing_version,
      xcodeproj: "iosApp.xcodeproj"
    ) unless marketing_version.to_s.empty?

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj: "iosApp.xcodeproj"
    )

    # ── Build ──────────────────────────────────────────────────────────────
    build_app(
      scheme:                      "iosApp",
      project:                     "iosApp.xcodeproj",
      configuration:               "Release",
      export_method:               "app-store",
      clean:                       true,
      output_directory:            "./build",
      output_name:                 "VPlanPlus.ipa",
      xcargs:                      "CODE_SIGN_STYLE=Manual " \
                                   "DEVELOPMENT_TEAM=BYCH2H5X5G " \
                                   "PROVISIONING_PROFILE_SPECIFIER=#{profile_uuid} " \
                                   "CODE_SIGN_IDENTITY=\"Apple Distribution\"",
      export_options: {
        method:                    "app-store",
        teamID:                    "BYCH2H5X5G",
        signingStyle:              "manual",
        provisioningProfiles: {
          "plus.vplan.app.VPlanPlus" => profile_uuid
        }
      }
    )

    # ── Upload to TestFlight ───────────────────────────────────────────────
    upload_to_testflight(
      ipa:             "./build/VPlanPlus.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
